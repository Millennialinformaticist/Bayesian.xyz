{
  "mcpServers": {
    "hyperliquid": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--read-only",
        "--tmpfs",
        "/tmp:rw,noexec,nosuid,size=16m",
        "--cap-drop=ALL",
        "--security-opt",
        "no-new-privileges",
        "hyperliquid-mcp:0.0.1-vetted"
      ]
    }
  }
}
